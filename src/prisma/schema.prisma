//   roleid Int
//   permissionid Int
//   role Roles @relation(fields: [roleid], references: [id])
//   permission Permission @relation(fields: [permissionid], references: [id])
// }

model UserAuth {
  id Int @id @default(autoincrement())
  name String
  password String
  email String @unique
  userdata UserData?
}

model UserData {
  id Int @id @default(autoincrement())
  userid Int @unique
  user UserAuth @relation(fields: [userid], references: [id])
  status String // status :: Active or inactive or banned
  roleid Int
  role Roles @relation(fields: [roleid], references: [id])
}

model FinanceData {
  id Int @id @default(autoincrement())
  amount Int
  category String
  type String
  date DateTime
  notes String
}